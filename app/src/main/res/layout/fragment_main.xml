<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_default"
    android:padding="16dp">

    <!-- Заголовок -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/blue_primary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MeteoNode"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Умное устройство твоего комфорта"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:alpha="0.9"
                android:gravity="center"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Статус и кнопка подключения -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        android:layout_marginBottom="16dp"
        app:cardElevation="2dp"
        android:id="@+id/connectionCard"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ПОДКЛЮЧЕНИЕ"
                    android:textSize="12sp"
                    android:textColor="@color/gray_dark"/>

                <TextView
                    android:id="@+id/tvConnectionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Устройство не подключено"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray_dark"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/btnQuickConnect"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_sync"
                android:tint="@color/blue_primary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ОСНОВНЫЕ ПОКАЗАТЕЛИ -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ОСНОВНЫЕ ПОКАЗАТЕЛИ"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/blue_dark"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:gravity="center">

        <!-- Температура -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background_default">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">


                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_thermostat"
                    android:tint="@color/blue_primary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvTemperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22.5°"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_default"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Температура"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_default"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Влажность -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background_default">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_humidity"
                    android:tint="@color/blue_primary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvHumidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45%"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_default"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Влажность"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_default"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Давление -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background_default">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_pressure"
                    android:tint="@color/blue_primary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvPressure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="760"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_default"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Давление"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_default"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- КАЧЕСТВО ВОЗДУХА -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="КАЧЕСТВО ВОЗДУХА"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/blue_dark"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="4dp"/>

    <!-- AQI с цельной шкалой -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        android:layout_marginBottom="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/card_background_default">  <!-- Добавлено -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Подписи качества над шкалой -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Идеально"
                    android:textSize="10sp"
                    android:textColor="@color/level_1"
                    android:gravity="center"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Хорошо"
                    android:textSize="10sp"
                    android:textColor="@color/level_2"
                    android:gravity="center"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Средне"
                    android:textSize="10sp"
                    android:textColor="@color/level_3"
                    android:gravity="center"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Плохо"
                    android:textSize="10sp"
                    android:textColor="@color/level_4"
                    android:gravity="center"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Опасно"
                    android:textSize="10sp"
                    android:textColor="@color/level_5"
                    android:gravity="center"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Цельная шкала -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="4dp">

                <View
                    android:id="@+id/scaleBackground"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/scale_gradient"/>

                <ImageView
                    android:id="@+id/scaleIndicator"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_indicator"
                    android:tint="@color/white"
                    android:layout_gravity="center_vertical"
                    android:elevation="4dp"
                    android:visibility="gone"/>

            </FrameLayout>



            <!-- Описание -->
            <TextView
                android:id="@+id/tvAqiDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Качество воздуха хорошее"
                android:textSize="12sp"
                android:textColor="@color/level_2"
                android:textStyle="italic"
                android:gravity="center"
                android:padding="4dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- CO2 и TVOC -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- CO2 -->
        <!-- CO2 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background_default">  <!-- Добавлено -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_co2"
                    android:tint="@color/blue_primary"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CO₂"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary_default"/>  <!-- Изменено -->

                    <TextView
                        android:id="@+id/tvCo2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="450 ppm"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_default"/>  <!-- Изменено -->

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TVOC -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_background_default">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_tvoc"
                    android:tint="@color/blue_primary"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TVOC"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary_default"/>

                    <TextView
                        android:id="@+id/tvTvoc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="120 ppb"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_default"/>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>